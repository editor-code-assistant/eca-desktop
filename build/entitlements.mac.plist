<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTD/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        Entitlements for hardened runtime + notarization.
        Required for Electron apps under macOS Gatekeeper.
        See: https://www.electron.build/configuration/mac#MacConfiguration-entitlements
    -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- TODO: verify after notarization roundtrip -->
    <!-- Removed: allow-unsigned-executable-memory, disable-library-validation,
         allow-dyld-environment-variables. These weaken the hardened runtime
         and are not required for a vanilla Electron build. Restore only if
         notarization or code-signing fails. -->
</dict>
</plist>
